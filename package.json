{
  "name": "bunqueue-dashboard",
  "version": "0.0.14",
  "type": "module",
  "description": "Web dashboard for a bunqueue server (queues, jobs, DLQ, cron, metrics, workers, live activity). Run with `bunx bunqueue-dashboard` (requires Bun).",
  "bin": {
    "bunqueue-dashboard": "scripts/serve.ts"
  },
  "files": [
    "dist",
    "scripts/serve.ts",
    "scripts/embedded.gen.ts",
    "agent",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Egeo Minotti",
  "homepage": "https://github.com/egeominotti/bunqueue-dashboard#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/egeominotti/bunqueue-dashboard.git"
  },
  "bugs": {
    "url": "https://github.com/egeominotti/bunqueue-dashboard/issues"
  },
  "keywords": [
    "bunqueue",
    "dashboard",
    "queue",
    "jobs",
    "react",
    "vite",
    "bun"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "prepack": "bun run build && bun scripts/gen-embed.ts",
    "start": "bun run scripts/dev.ts",
    "dev": "vite",
    "agent": "bun run agent/index.ts",
    "build": "tsc --noEmit && vite build",
    "size": "bun run scripts/check-bundle.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "build:bin": "bun run build && bun run scripts/gen-embed.ts && bun build scripts/serve.ts --compile --minify --outfile bunqueue-dashboard",
    "preview": "vite preview",
    "test": "bun test",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^4.0.7",
    "@ai-sdk/google": "^4.0.8",
    "@ai-sdk/openai": "^4.0.7",
    "@ai-sdk/openai-compatible": "^3.0.5",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "ai": "^7.0.14",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14",
    "@biomejs/biome": "^2.5.2",
    "@shikijs/vitepress-twoslash": "^4.3.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "mermaid": "^11.16.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitepress": "^1.6.4",
    "vitepress-plugin-llms": "^1.13.2",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
