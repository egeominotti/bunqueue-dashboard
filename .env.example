# Copy to `.env` and adjust. All dashboard vars are build-time (VITE_*) and can
# also be overridden at runtime from the in-app Settings page.

# bunqueue server origin. In dev, leave unset — requests to `/api/*` are proxied
# to http://localhost:6790 by Vite. In prod (Docker / Pages), set the reachable
# server origin, e.g. https://queue.example.com
# VITE_BUNQUEUE_URL=

# Bearer token, only if the bunqueue server was started with AUTH_TOKENS set.
# VITE_BUNQUEUE_TOKEN=

# Control-agent origin (start/stop/restart). Defaults to http://localhost:6800.
# VITE_BUNQUEUE_AGENT_URL=

# ---- Control agent (agent/index.ts) -----------------------------------------
# AGENT_PORT=6800
# Extra browser origins allowed to drive the agent (comma-separated).
# AGENT_ALLOWED_ORIGINS=
# Optional bearer token required on state-changing agent requests.
# AGENT_TOKEN=
